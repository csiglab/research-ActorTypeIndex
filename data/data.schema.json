{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EntitiesSchema",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the dataset or collection."
    },
    "entities": {
      "type": "array",
      "description": "List of entities in the system.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique identifier for the entity."
          },
          "name": {
            "type": "string",
            "description": "Name of the entity."
          },
          "categories": {
            "type": "array",
            "description": "High-level classifications of the entity.",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "description": "Descriptors for the entity; only 'actor' or 'type' are allowed.",
            "items": {
              "type": "string",
              "enum": ["actor", "type"]
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "desc": {
            "type": "string",
            "description": "Detailed description of the entity."
          },
          "link": {
            "type": "string",
            "format": "uri",
            "description": "Reference link for more information about the entity."
          },
          "icon": {
            "type": "string",
            "description": "Emoji or icon representing the entity."
          }
        },
        "required": ["id", "name", "categories", "tags", "desc", "link", "icon"]
      }
    }
  },
  "required": ["metadata", "entities"]
}